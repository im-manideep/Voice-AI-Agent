# Copy to .env — .env is gitignored, never commit it.

# LLM provider: ollama (free, local) | openai (paid)
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Only needed when LLM_PROVIDER=openai (Tier 2). Keys stay server-side.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Voice tier: free (browser Web Speech) | pro (streamed Whisper + Cartesia/ElevenLabs)
VOICE_TIER=free
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# Dev only: allow force_verdict in /turn for the scripted scheduler proof.
RECALL_ALLOW_FORCE_VERDICT=1
